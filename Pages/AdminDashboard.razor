@page "/admin"
@inject IAdminService AdminService
@inject IPackageService PackageService
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>Admin Dashboard - Klacks Marketplace</PageTitle>

<div class="detail-container" style="max-width: 1000px;">
    <h1><i class="fas fa-shield-alt"></i> Admin Dashboard</h1>

    @if (!_isAdmin)
    {
        <div class="alert alert-danger">Access denied. Admin privileges required.</div>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <div class="alert alert-success">@_message</div>
        }

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <div class="alert alert-danger">@_errorMessage</div>
        }

        <div class="admin-stats">
            <div class="stat-card">
                <div class="stat-number">@_pendingPackages.Count</div>
                <div class="stat-label">Pending Packages</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">@_pendingPlugins.Count</div>
                <div class="stat-label">Pending Plugins</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">@_users.Count</div>
                <div class="stat-label">Users</div>
            </div>
        </div>

        <h3 class="mb-3">Pending Language Packages</h3>
        @if (_pendingPackages.Count == 0)
        {
            <div class="alert alert-info">No packages pending review.</div>
        }
        else
        {
            <div class="table-responsive mb-4">
                <table class="table table-dark-custom">
                    <thead>
                        <tr>
                            <th>Package</th>
                            <th>Author</th>
                            <th>Code</th>
                            <th>Coverage</th>
                            <th>Docs</th>
                            <th>Submitted</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var pkg in _pendingPackages)
                        {
                            <tr>
                                <td><a href="/package/@pkg.Code">@pkg.DisplayName</a></td>
                                <td>@pkg.Author.DisplayName</td>
                                <td><code>@pkg.Code</code></td>
                                <td>@pkg.Coverage.ToString("F0")%</td>
                                <td>@GetDocsCount(pkg)</td>
                                <td>@pkg.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td>
                                    <button class="btn btn-outline-success btn-sm" @onclick="() => ApprovePackage(pkg.Id)">
                                        <i class="fas fa-check"></i>
                                    </button>
                                    <button class="btn btn-outline-danger btn-sm ms-1" @onclick="() => RejectPackage(pkg.Id)">
                                        <i class="fas fa-times"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <h3 class="mb-3">Pending Feature Plugins</h3>
        @if (_pendingPlugins.Count == 0)
        {
            <div class="alert alert-info">No plugins pending review.</div>
        }
        else
        {
            <div class="table-responsive mb-4">
                <table class="table table-dark-custom">
                    <thead>
                        <tr>
                            <th>Plugin</th>
                            <th>Author</th>
                            <th>Category</th>
                            <th>Version</th>
                            <th>Submitted</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var plugin in _pendingPlugins)
                        {
                            <tr>
                                <td><a href="/plugin/@plugin.Name">@plugin.DisplayName</a></td>
                                <td>@plugin.Author.DisplayName</td>
                                <td><CategoryBadge Category="@plugin.Category" /></td>
                                <td>@plugin.Version</td>
                                <td>@plugin.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td>
                                    <button class="btn btn-outline-success btn-sm" @onclick="() => ApprovePlugin(plugin.Id)">
                                        <i class="fas fa-check"></i>
                                    </button>
                                    <button class="btn btn-outline-danger btn-sm ms-1" @onclick="() => RejectPlugin(plugin.Id)">
                                        <i class="fas fa-times"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <h3 class="mb-3">Users</h3>
        <div class="table-responsive">
            <table class="table table-dark-custom">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Joined</th>
                        <th>Admin</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in _users)
                    {
                        <tr>
                            <td>@user.DisplayName</td>
                            <td>@user.Email</td>
                            <td>@user.CreatedAt.ToString("yyyy-MM-dd")</td>
                            <td>
                                @if (user.IsAdmin)
                                {
                                    <span class="status-badge status-published">Admin</span>
                                }
                            </td>
                            <td>
                                <button class="btn btn-outline-primary btn-sm" @onclick="() => ToggleAdmin(user.Id)">
                                    @(user.IsAdmin ? "Remove Admin" : "Make Admin")
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <ConfirmDialog IsVisible="@_showConfirmReject"
                       Title="@_rejectTitle"
                       Message="@_rejectMessage"
                       OnConfirm="ConfirmReject"
                       OnCancel="CancelReject" />
    }
</div>

@code {
    private bool _isAdmin;
    private List<LanguagePackage> _pendingPackages = [];
    private List<FeaturePlugin> _pendingPlugins = [];
    private List<User> _users = [];
    private string _message = string.Empty;
    private string _errorMessage = string.Empty;
    private bool _showConfirmReject;
    private int _rejectItemId;
    private string _rejectType = string.Empty;
    private string _rejectTitle = string.Empty;
    private string _rejectMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var user = HttpContextAccessor.HttpContext?.User;
        _isAdmin = user?.IsInRole("Admin") ?? false;

        if (_isAdmin)
        {
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        _pendingPackages = await AdminService.GetPendingPackagesAsync();
        _pendingPlugins = await AdminService.GetPendingPluginsAsync();
        _users = await AdminService.GetUsersAsync();
    }

    private async Task ApprovePackage(int packageId)
    {
        try
        {
            await AdminService.ApprovePackageAsync(packageId);
            _message = "Package approved successfully";
            await LoadData();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private void RejectPackage(int packageId)
    {
        _rejectItemId = packageId;
        _rejectType = "package";
        _rejectTitle = "Reject Package";
        _rejectMessage = "Are you sure you want to reject this package?";
        _showConfirmReject = true;
    }

    private async Task ApprovePlugin(int pluginId)
    {
        try
        {
            await AdminService.ApprovePluginAsync(pluginId);
            _message = "Plugin approved successfully";
            await LoadData();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private void RejectPlugin(int pluginId)
    {
        _rejectItemId = pluginId;
        _rejectType = "plugin";
        _rejectTitle = "Reject Plugin";
        _rejectMessage = "Are you sure you want to reject this plugin?";
        _showConfirmReject = true;
    }

    private async Task ConfirmReject()
    {
        try
        {
            if (_rejectType == "package")
            {
                await AdminService.RejectPackageAsync(_rejectItemId, "Rejected by admin");
                _message = "Package rejected";
            }
            else
            {
                await AdminService.RejectPluginAsync(_rejectItemId, "Rejected by admin");
                _message = "Plugin rejected";
            }
            _showConfirmReject = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            _showConfirmReject = false;
        }
    }

    private void CancelReject()
    {
        _showConfirmReject = false;
    }

    private static string GetDocsCount(LanguagePackage pkg)
    {
        var latestVersion = pkg.Versions.FirstOrDefault();
        if (latestVersion is null || string.IsNullOrWhiteSpace(latestVersion.DocsJson))
        {
            return "0";
        }

        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(latestVersion.DocsJson);
            return doc.RootElement.EnumerateObject().Count().ToString();
        }
        catch
        {
            return "0";
        }
    }

    private async Task ToggleAdmin(int userId)
    {
        try
        {
            await AdminService.ToggleAdminAsync(userId);
            _message = "User role updated";
            await LoadData();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }
}
