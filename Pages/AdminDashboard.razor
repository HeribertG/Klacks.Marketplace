@page "/admin"
@inject IAdminService AdminService
@inject IPackageService PackageService
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>Admin Dashboard - Klacks Store</PageTitle>

<div class="max-w-5xl mx-auto px-6 py-8">
    <h1 class="text-3xl font-black tracking-tight mb-8">
        <span class="material-symbols-outlined text-3xl mr-2 align-middle">admin_panel_settings</span> Admin Dashboard
    </h1>

    @if (!_isAdmin)
    {
        <div class="bg-error-container text-on-error-container rounded-xl px-6 py-4">Access denied. Admin privileges required.</div>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <div class="bg-tertiary-fixed text-on-tertiary-fixed-variant rounded-xl px-6 py-4 mb-6">@_message</div>
        }

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <div class="bg-error-container text-on-error-container rounded-xl px-6 py-4 mb-6">@_errorMessage</div>
        }

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="bg-surface-container-lowest rounded-xl p-6 text-center shadow-[0_4px_12px_rgba(27,27,29,0.04)]">
                <div class="text-3xl font-black text-secondary">@_pendingPackages.Count</div>
                <div class="text-xs text-on-surface-variant uppercase tracking-wider mt-1">Pending Packages</div>
            </div>
            <div class="bg-surface-container-lowest rounded-xl p-6 text-center shadow-[0_4px_12px_rgba(27,27,29,0.04)]">
                <div class="text-3xl font-black text-secondary">@_pendingPlugins.Count</div>
                <div class="text-xs text-on-surface-variant uppercase tracking-wider mt-1">Pending Plugins</div>
            </div>
            <div class="bg-surface-container-lowest rounded-xl p-6 text-center shadow-[0_4px_12px_rgba(27,27,29,0.04)]">
                <div class="text-3xl font-black text-secondary">@_users.Count</div>
                <div class="text-xs text-on-surface-variant uppercase tracking-wider mt-1">Users</div>
            </div>
        </div>

        <h3 class="text-xl font-bold mb-4">Pending Language Packages</h3>
        @if (_pendingPackages.Count == 0)
        {
            <div class="bg-secondary-fixed text-on-secondary-fixed-variant rounded-xl px-6 py-4 mb-8">No packages pending review.</div>
        }
        else
        {
            <div class="bg-surface-container-lowest rounded-xl overflow-hidden shadow-[0_4px_12px_rgba(27,27,29,0.04)] mb-8">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="bg-surface-container-low text-on-surface-variant text-xs uppercase tracking-wider">
                            <th class="px-6 py-4 text-left font-bold">Package</th>
                            <th class="px-6 py-4 text-left font-bold">Author</th>
                            <th class="px-6 py-4 text-left font-bold">Code</th>
                            <th class="px-6 py-4 text-left font-bold">Coverage</th>
                            <th class="px-6 py-4 text-left font-bold">Docs</th>
                            <th class="px-6 py-4 text-left font-bold">Submitted</th>
                            <th class="px-6 py-4 text-left font-bold">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-outline-variant/20">
                        @foreach (var pkg in _pendingPackages)
                        {
                            <tr class="hover:bg-surface-container-low/50 transition-colors">
                                <td class="px-6 py-4"><a href="/package/@pkg.Code" class="text-secondary hover:underline no-underline font-medium">@pkg.DisplayName</a></td>
                                <td class="px-6 py-4">@pkg.Author.DisplayName</td>
                                <td class="px-6 py-4"><code class="text-xs bg-surface-container-low px-2 py-1 rounded">@pkg.Code</code></td>
                                <td class="px-6 py-4">@pkg.Coverage.ToString("F0")%</td>
                                <td class="px-6 py-4">@GetDocsCount(pkg)</td>
                                <td class="px-6 py-4">@pkg.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td class="px-6 py-4">
                                    <button class="px-3 py-1.5 bg-tertiary-fixed text-on-tertiary-fixed-variant rounded-lg text-xs font-bold hover:opacity-80 transition-all" @onclick="() => ApprovePackage(pkg.Id)">
                                        <span class="material-symbols-outlined text-[16px]">check</span>
                                    </button>
                                    <button class="px-3 py-1.5 bg-error-container text-on-error-container rounded-lg text-xs font-bold hover:opacity-80 transition-all ml-2" @onclick="() => RejectPackage(pkg.Id)">
                                        <span class="material-symbols-outlined text-[16px]">close</span>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <h3 class="text-xl font-bold mb-4">Pending Feature Plugins</h3>
        @if (_pendingPlugins.Count == 0)
        {
            <div class="bg-secondary-fixed text-on-secondary-fixed-variant rounded-xl px-6 py-4 mb-8">No plugins pending review.</div>
        }
        else
        {
            <div class="bg-surface-container-lowest rounded-xl overflow-hidden shadow-[0_4px_12px_rgba(27,27,29,0.04)] mb-8">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="bg-surface-container-low text-on-surface-variant text-xs uppercase tracking-wider">
                            <th class="px-6 py-4 text-left font-bold">Plugin</th>
                            <th class="px-6 py-4 text-left font-bold">Author</th>
                            <th class="px-6 py-4 text-left font-bold">Category</th>
                            <th class="px-6 py-4 text-left font-bold">Version</th>
                            <th class="px-6 py-4 text-left font-bold">Submitted</th>
                            <th class="px-6 py-4 text-left font-bold">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-outline-variant/20">
                        @foreach (var plugin in _pendingPlugins)
                        {
                            <tr class="hover:bg-surface-container-low/50 transition-colors">
                                <td class="px-6 py-4"><a href="/plugin/@plugin.Name" class="text-secondary hover:underline no-underline font-medium">@plugin.DisplayName</a></td>
                                <td class="px-6 py-4">@plugin.Author.DisplayName</td>
                                <td class="px-6 py-4"><CategoryBadge Category="@plugin.Category" /></td>
                                <td class="px-6 py-4">@plugin.Version</td>
                                <td class="px-6 py-4">@plugin.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td class="px-6 py-4">
                                    <button class="px-3 py-1.5 bg-tertiary-fixed text-on-tertiary-fixed-variant rounded-lg text-xs font-bold hover:opacity-80 transition-all" @onclick="() => ApprovePlugin(plugin.Id)">
                                        <span class="material-symbols-outlined text-[16px]">check</span>
                                    </button>
                                    <button class="px-3 py-1.5 bg-error-container text-on-error-container rounded-lg text-xs font-bold hover:opacity-80 transition-all ml-2" @onclick="() => RejectPlugin(plugin.Id)">
                                        <span class="material-symbols-outlined text-[16px]">close</span>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <h3 class="text-xl font-bold mb-4">Users</h3>
        <div class="bg-surface-container-lowest rounded-xl overflow-hidden shadow-[0_4px_12px_rgba(27,27,29,0.04)]">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-surface-container-low text-on-surface-variant text-xs uppercase tracking-wider">
                        <th class="px-6 py-4 text-left font-bold">Name</th>
                        <th class="px-6 py-4 text-left font-bold">Email</th>
                        <th class="px-6 py-4 text-left font-bold">Joined</th>
                        <th class="px-6 py-4 text-left font-bold">Admin</th>
                        <th class="px-6 py-4 text-left font-bold">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-outline-variant/20">
                    @foreach (var user in _users)
                    {
                        <tr class="hover:bg-surface-container-low/50 transition-colors">
                            <td class="px-6 py-4">@user.DisplayName</td>
                            <td class="px-6 py-4">@user.Email</td>
                            <td class="px-6 py-4">@user.CreatedAt.ToString("yyyy-MM-dd")</td>
                            <td class="px-6 py-4">
                                @if (user.IsAdmin)
                                {
                                    <span class="px-3 py-1 bg-tertiary-fixed text-on-tertiary-fixed-variant rounded-full text-xs font-bold">Admin</span>
                                }
                            </td>
                            <td class="px-6 py-4">
                                <button class="px-3 py-1.5 bg-secondary text-on-secondary rounded-lg text-xs font-bold hover:opacity-80 transition-all" @onclick="() => ToggleAdmin(user.Id)">
                                    @(user.IsAdmin ? "Remove Admin" : "Make Admin")
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <ConfirmDialog IsVisible="@_showConfirmReject"
                       Title="@_rejectTitle"
                       Message="@_rejectMessage"
                       OnConfirm="ConfirmReject"
                       OnCancel="CancelReject" />
    }
</div>

@code {
    private bool _isAdmin;
    private List<LanguagePackage> _pendingPackages = [];
    private List<FeaturePlugin> _pendingPlugins = [];
    private List<User> _users = [];
    private string _message = string.Empty;
    private string _errorMessage = string.Empty;
    private bool _showConfirmReject;
    private int _rejectItemId;
    private string _rejectType = string.Empty;
    private string _rejectTitle = string.Empty;
    private string _rejectMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var user = HttpContextAccessor.HttpContext?.User;
        _isAdmin = user?.IsInRole("Admin") ?? false;

        if (_isAdmin)
        {
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        _pendingPackages = await AdminService.GetPendingPackagesAsync();
        _pendingPlugins = await AdminService.GetPendingPluginsAsync();
        _users = await AdminService.GetUsersAsync();
    }

    private async Task ApprovePackage(int packageId)
    {
        try
        {
            await AdminService.ApprovePackageAsync(packageId);
            _message = "Package approved successfully";
            await LoadData();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private void RejectPackage(int packageId)
    {
        _rejectItemId = packageId;
        _rejectType = "package";
        _rejectTitle = "Reject Package";
        _rejectMessage = "Are you sure you want to reject this package?";
        _showConfirmReject = true;
    }

    private async Task ApprovePlugin(int pluginId)
    {
        try
        {
            await AdminService.ApprovePluginAsync(pluginId);
            _message = "Plugin approved successfully";
            await LoadData();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private void RejectPlugin(int pluginId)
    {
        _rejectItemId = pluginId;
        _rejectType = "plugin";
        _rejectTitle = "Reject Plugin";
        _rejectMessage = "Are you sure you want to reject this plugin?";
        _showConfirmReject = true;
    }

    private async Task ConfirmReject()
    {
        try
        {
            if (_rejectType == "package")
            {
                await AdminService.RejectPackageAsync(_rejectItemId, "Rejected by admin");
                _message = "Package rejected";
            }
            else
            {
                await AdminService.RejectPluginAsync(_rejectItemId, "Rejected by admin");
                _message = "Plugin rejected";
            }
            _showConfirmReject = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            _showConfirmReject = false;
        }
    }

    private void CancelReject()
    {
        _showConfirmReject = false;
    }

    private static string GetDocsCount(LanguagePackage pkg)
    {
        var latestVersion = pkg.Versions.FirstOrDefault();
        if (latestVersion is null || string.IsNullOrWhiteSpace(latestVersion.DocsJson))
        {
            return "0";
        }

        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(latestVersion.DocsJson);
            return doc.RootElement.EnumerateObject().Count().ToString();
        }
        catch
        {
            return "0";
        }
    }

    private async Task ToggleAdmin(int userId)
    {
        try
        {
            await AdminService.ToggleAdminAsync(userId);
            _message = "User role updated";
            await LoadData();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }
}
