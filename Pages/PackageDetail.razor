@page "/package/{Code}"
@inject IPackageService PackageService
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L

<PageTitle>@(_package?.DisplayName ?? L["Common_Package"]) - Klacks Store</PageTitle>

@if (_isLoading)
{
    <div class="flex justify-center py-24 bg-surface">
        <div class="animate-spin w-8 h-8 border-4 border-secondary border-t-transparent rounded-full"></div>
    </div>
}
else if (_package is null)
{
    <section class="py-24 px-6 bg-surface text-center">
        <span class="material-symbols-outlined text-6xl text-on-surface-variant mb-4 block">warning</span>
        <h3 class="text-2xl font-bold mb-2">@L["PackageDetail_NotFound"]</h3>
        <p class="text-on-surface-variant mb-6">@L["PackageDetail_NotFoundDesc"]</p>
        <a href="/" class="px-6 py-3 bg-secondary text-on-secondary rounded-lg font-semibold no-underline hover:opacity-90 transition-all">@L["Common_BackToBrowse"]</a>
    </section>
}
else
{
    <div class="max-w-5xl mx-auto px-6 py-8">
        <nav class="flex items-center gap-2 text-sm text-on-surface-variant mb-8">
            <a href="/" class="hover:text-secondary transition-colors no-underline text-on-surface-variant">@L["Common_Home"]</a>
            <span class="material-symbols-outlined text-[16px]">chevron_right</span>
            <span>@L["Common_LanguagePacks"]</span>
            <span class="material-symbols-outlined text-[16px]">chevron_right</span>
            <span class="text-on-surface font-medium">@_package.DisplayName</span>
        </nav>

        <div class="bg-surface-container-low rounded-2xl p-8 mb-8">
            <div class="flex flex-col md:flex-row gap-8">
                <div class="flex-1">
                    <div class="flex items-center gap-4 mb-4">
                        <span class="text-5xl">@GetFlagEmoji(_package.Code)</span>
                        <div>
                            <h1 class="text-3xl font-black tracking-tight">@_package.DisplayName</h1>
                            <span class="text-on-surface-variant font-mono">@_package.Code</span>
                        </div>
                    </div>
                    <div class="flex items-center gap-3 mb-4 flex-wrap">
                        <span class="text-on-surface-variant flex items-center gap-1">
                            <span class="material-symbols-outlined text-[18px]">person</span> @_package.Author.DisplayName
                        </span>
                        <span class="px-2 py-1 bg-surface-container text-xs font-bold rounded uppercase tracking-wider text-on-surface-variant">v@(_package.Version)</span>
                        <StatusBadge Status="@_package.Status" />
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_package.Description))
                    {
                        <p class="text-on-surface leading-relaxed">@_package.Description</p>
                    }
                </div>

                <div class="w-full md:w-72 flex flex-col gap-4">
                    @if (_package.Status == PackageStatus.Published)
                    {
                        <button class="w-full px-6 py-4 bg-secondary text-on-secondary rounded-xl font-bold text-lg hover:opacity-90 active:scale-[0.98] transition-all flex items-center justify-center gap-2 disabled:opacity-50"
                                @onclick="DownloadPackage" disabled="@_isDownloading">
                            @if (_isDownloading)
                            {
                                <div class="animate-spin w-5 h-5 border-2 border-white border-t-transparent rounded-full"></div>
                            }
                            else
                            {
                                <span class="material-symbols-outlined">download</span>
                            }
                            @L["Common_Download"]
                        </button>
                    }
                    <div class="space-y-3 text-sm text-on-surface-variant">
                        <div class="flex items-center justify-between">
                            <span>@L["Common_Downloads"]</span>
                            <span class="font-bold text-on-surface">@_package.Downloads</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <span>@L["Common_MinVersion"]</span>
                            <span class="font-bold text-on-surface">v@(_package.MinKlacksVersion)</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <span>@L["PackageDetail_SpeechLocale"]</span>
                            <span class="font-bold text-on-surface">@_package.SpeechLocale</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-surface-container-lowest rounded-2xl p-8 mb-8 shadow-[0_4px_12px_rgba(27,27,29,0.04)]">
            <h3 class="text-lg font-bold mb-4">@L["PackageDetail_TranslationCoverage"]</h3>
            <div class="flex justify-between text-sm font-bold mb-2">
                <span>@L["PackageDetail_TranslationCount", _package.TranslationCount]</span>
                <span class="text-on-tertiary-container">@(_package.Coverage)%</span>
            </div>
            <div class="w-full bg-surface-container h-3 rounded-full overflow-hidden">
                <div class="bg-gradient-to-r from-tertiary-fixed-dim to-on-tertiary-container h-full transition-all" style="width: @(_package.Coverage)%"></div>
            </div>
        </div>

        @if (_docsCount > 0 || _countriesCount > 0 || _statesCount > 0 || _calendarRulesCount > 0)
        {
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
                @if (_docsCount > 0)
                {
                    <div class="bg-surface-container-lowest rounded-xl p-6 text-center shadow-[0_4px_12px_rgba(27,27,29,0.04)]">
                        <span class="material-symbols-outlined text-3xl text-secondary mb-2 block">menu_book</span>
                        <div class="text-2xl font-black">@_docsCount</div>
                        <div class="text-xs text-on-surface-variant uppercase tracking-wider">@L["PackageDetail_Manuals"]</div>
                    </div>
                }
                @if (_countriesCount > 0)
                {
                    <div class="bg-surface-container-lowest rounded-xl p-6 text-center shadow-[0_4px_12px_rgba(27,27,29,0.04)]">
                        <span class="material-symbols-outlined text-3xl text-secondary mb-2 block">public</span>
                        <div class="text-2xl font-black">@_countriesCount</div>
                        <div class="text-xs text-on-surface-variant uppercase tracking-wider">@L["PackageDetail_Countries"]</div>
                    </div>
                }
                @if (_statesCount > 0)
                {
                    <div class="bg-surface-container-lowest rounded-xl p-6 text-center shadow-[0_4px_12px_rgba(27,27,29,0.04)]">
                        <span class="material-symbols-outlined text-3xl text-secondary mb-2 block">location_on</span>
                        <div class="text-2xl font-black">@_statesCount</div>
                        <div class="text-xs text-on-surface-variant uppercase tracking-wider">@L["PackageDetail_States"]</div>
                    </div>
                }
                @if (_calendarRulesCount > 0)
                {
                    <div class="bg-surface-container-lowest rounded-xl p-6 text-center shadow-[0_4px_12px_rgba(27,27,29,0.04)]">
                        <span class="material-symbols-outlined text-3xl text-secondary mb-2 block">calendar_month</span>
                        <div class="text-2xl font-black">@_calendarRulesCount</div>
                        <div class="text-xs text-on-surface-variant uppercase tracking-wider">@L["PackageDetail_CalendarRules"]</div>
                    </div>
                }
            </div>
        }

        @if (_package.Versions.Count > 0)
        {
            <div class="mb-8">
                <h3 class="text-lg font-bold mb-4">@L["Common_VersionHistory"]</h3>
                <div class="space-y-3">
                    @foreach (var version in _package.Versions)
                    {
                        <div class="bg-surface-container-lowest rounded-xl p-5 flex items-start justify-between shadow-[0_4px_12px_rgba(27,27,29,0.04)]">
                            <div>
                                <span class="font-bold">v@(version.Version)</span>
                                <span class="text-on-surface-variant text-sm ml-3">@version.CreatedAt.ToString("D")</span>
                                @if (!string.IsNullOrWhiteSpace(version.ChangeLog))
                                {
                                    <p class="text-on-surface-variant text-sm mt-1 mb-0">@version.ChangeLog</p>
                                }
                            </div>
                            <StatusBadge Status="@version.Status" />
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="max-w-5xl mx-auto px-6 mb-8">
            <div class="bg-error-container text-on-error-container rounded-xl p-4">@_errorMessage</div>
        </div>
    }
}

@code {
    [Parameter]
    public string Code { get; set; } = string.Empty;

    private LanguagePackage? _package;
    private bool _isLoading = true;
    private bool _isDownloading;
    private int _docsCount;
    private int _countriesCount;
    private int _statesCount;
    private int _calendarRulesCount;
    private string _errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _package = await PackageService.GetPackageByCodeAsync(Code);
        ComputeGeoDataCounts();
        _isLoading = false;
    }

    private void ComputeGeoDataCounts()
    {
        var latestVersion = _package?.Versions.FirstOrDefault();
        if (latestVersion is null) return;

        _docsCount = CountJsonEntries(latestVersion.DocsJson, isObject: true);
        _countriesCount = CountJsonEntries(latestVersion.CountriesJson, isObject: false);
        _statesCount = CountJsonEntries(latestVersion.StatesJson, isObject: false);
        _calendarRulesCount = CountJsonEntries(latestVersion.CalendarRulesJson, isObject: false);
    }

    private static int CountJsonEntries(string json, bool isObject)
    {
        if (string.IsNullOrWhiteSpace(json)) return 0;
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            return isObject
                ? doc.RootElement.EnumerateObject().Count()
                : doc.RootElement.GetArrayLength();
        }
        catch { return 0; }
    }

    private async Task DownloadPackage()
    {
        try
        {
            _isDownloading = true;
            var ipAddress = HttpContextAccessor.HttpContext?.Connection.RemoteIpAddress?.ToString() ?? "unknown";
            var data = await PackageService.DownloadPackageAsync(Code, ipAddress);
            _package = await PackageService.GetPackageByCodeAsync(Code);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isDownloading = false;
        }
    }

    private static string GetFlagEmoji(string code)
    {
        var key = code.Length >= 5 ? code[3..5].ToUpperInvariant() : code[..2].ToUpperInvariant();
        var langToCountry = new Dictionary<string, string>
        {
            ["SV"] = "SE", ["JA"] = "JP", ["KO"] = "KR", ["EN"] = "GB",
            ["DA"] = "DK", ["ZH"] = "CN", ["HI"] = "IN", ["UK"] = "UA",
            ["VI"] = "VN", ["EL"] = "GR", ["CS"] = "CZ", ["HE"] = "IL",
            ["CA"] = "ES", ["EU"] = "ES", ["GL"] = "ES", ["NB"] = "NO",
            ["NN"] = "NO", ["SR"] = "RS", ["HR"] = "HR", ["BS"] = "BA",
            ["SL"] = "SI", ["SK"] = "SK", ["ET"] = "EE", ["LV"] = "LV",
            ["LT"] = "LT", ["MS"] = "MY", ["TH"] = "TH", ["ID"] = "ID",
            ["FA"] = "IR", ["BG"] = "BG", ["RO"] = "RO", ["HU"] = "HU",
            ["FI"] = "FI", ["AR"] = "SA"
        };
        var country = langToCountry.GetValueOrDefault(key, key);
        return CountryToFlag(country);
    }

    private static string CountryToFlag(string countryCode)
    {
        if (countryCode.Length != 2) return "\U0001F310";
        var first = char.ConvertFromUtf32(0x1F1E6 + (countryCode[0] - 'A'));
        var second = char.ConvertFromUtf32(0x1F1E6 + (countryCode[1] - 'A'));
        return first + second;
    }
}
