@page "/upload-plugin"
@inject IFeaturePluginMarketplaceService PluginService
@inject IPluginValidationService PluginValidation
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation

<PageTitle>Upload Plugin - Klacks Marketplace</PageTitle>

<div class="max-w-4xl mx-auto px-6 py-8">
    <h1 class="text-3xl font-black tracking-tight mb-2">
        <span class="material-symbols-outlined text-[32px] align-middle mr-1">extension</span> Upload Feature Plugin
    </h1>
    <p class="text-on-surface-variant mb-8">Share your feature plugin with the community</p>

    @if (!_isAuthenticated)
    {
        <div class="bg-secondary-fixed text-on-secondary-fixed-variant rounded-lg p-4 mb-6 text-sm">
            Please <a href="/login" class="underline font-semibold">login</a> to upload plugins.
        </div>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <div class="bg-error-container text-on-error-container rounded-lg p-4 mb-6 text-sm">@_errorMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(_successMessage))
        {
            <div class="bg-tertiary-fixed text-on-tertiary-fixed-variant rounded-lg p-4 mb-6 text-sm">@_successMessage</div>
        }

        <EditForm Model="@_model" OnValidSubmit="HandleUpload">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div>
                    <label class="block text-sm font-semibold text-on-surface mb-2">Plugin Name (unique identifier)</label>
                    <InputText class="w-full px-4 py-3 bg-surface-container-low border border-outline-variant/30 rounded-lg text-on-surface focus:ring-2 focus:ring-secondary focus:bg-surface-container-lowest outline-none transition-all" @bind-Value="_model.Name" placeholder="e.g. messaging" />
                </div>
                <div>
                    <label class="block text-sm font-semibold text-on-surface mb-2">Display Name</label>
                    <InputText class="w-full px-4 py-3 bg-surface-container-low border border-outline-variant/30 rounded-lg text-on-surface focus:ring-2 focus:ring-secondary focus:bg-surface-container-lowest outline-none transition-all" @bind-Value="_model.DisplayName" placeholder="e.g. Messaging" />
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div>
                    <label class="block text-sm font-semibold text-on-surface mb-2">Category</label>
                    <InputSelect class="w-full px-4 py-3 bg-surface-container-low border border-outline-variant/30 rounded-lg text-on-surface focus:ring-2 focus:ring-secondary focus:bg-surface-container-lowest outline-none transition-all" @bind-Value="_model.Category">
                        <option value="">Select category...</option>
                        @foreach (var cat in PluginCategory.AllCategories)
                        {
                            <option value="@cat">@cat</option>
                        }
                    </InputSelect>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-on-surface mb-2">Version</label>
                    <InputText class="w-full px-4 py-3 bg-surface-container-low border border-outline-variant/30 rounded-lg text-on-surface focus:ring-2 focus:ring-secondary focus:bg-surface-container-lowest outline-none transition-all" @bind-Value="_model.Version" placeholder="1.0.0" />
                </div>
            </div>

            <div class="mb-6">
                <label class="block text-sm font-semibold text-on-surface mb-2">Description</label>
                <InputTextArea class="w-full px-4 py-3 bg-surface-container-low border border-outline-variant/30 rounded-lg text-on-surface focus:ring-2 focus:ring-secondary focus:bg-surface-container-lowest outline-none transition-all" @bind-Value="_model.Description" rows="3"
                               placeholder="Describe your feature plugin..." />
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div>
                    <label class="block text-sm font-semibold text-on-surface mb-2">Min Klacks Version</label>
                    <InputText class="w-full px-4 py-3 bg-surface-container-low border border-outline-variant/30 rounded-lg text-on-surface focus:ring-2 focus:ring-secondary focus:bg-surface-container-lowest outline-none transition-all" @bind-Value="_model.MinKlacksVersion" placeholder="1.0.0" />
                </div>
                <div>
                    <label class="block text-sm font-semibold text-on-surface mb-2">Changelog</label>
                    <InputText class="w-full px-4 py-3 bg-surface-container-low border border-outline-variant/30 rounded-lg text-on-surface focus:ring-2 focus:ring-secondary focus:bg-surface-container-lowest outline-none transition-all" @bind-Value="_model.ChangeLog" placeholder="What changed in this version?" />
                </div>
            </div>

            <div class="border-2 border-dashed border-outline-variant/50 rounded-xl p-8 text-center hover:border-secondary hover:bg-surface-container-low transition-all cursor-pointer mb-6">
                <span class="material-symbols-outlined text-4xl text-on-surface-variant mb-2 block">description</span>
                <p class="font-bold">manifest.json <span class="text-on-surface-variant text-sm">(required)</span></p>
                <InputFile OnChange="OnManifestSelected" accept=".json" />
                @if (_manifestLoaded)
                {
                    <span class="text-on-tertiary-container flex items-center justify-center gap-1 mt-2"><span class="material-symbols-outlined text-[18px]">check_circle</span> Loaded</span>
                }
            </div>

            <div class="border-2 border-dashed border-outline-variant/50 rounded-xl p-8 text-center hover:border-secondary hover:bg-surface-container-low transition-all cursor-pointer mb-6">
                <span class="material-symbols-outlined text-4xl text-on-surface-variant mb-2 block">translate</span>
                <p class="font-bold">en.json <span class="text-on-surface-variant text-sm">(required i18n)</span></p>
                <InputFile OnChange="OnEnI18nSelected" accept=".json" />
                @if (_enI18nLoaded)
                {
                    <span class="text-on-tertiary-container flex items-center justify-center gap-1 mt-2"><span class="material-symbols-outlined text-[18px]">check_circle</span> Loaded</span>
                }
            </div>

            <div class="border-2 border-dashed border-outline-variant/50 rounded-xl p-8 text-center hover:border-secondary hover:bg-surface-container-low transition-all cursor-pointer mb-6">
                <span class="material-symbols-outlined text-4xl text-on-surface-variant mb-2 block">translate</span>
                <p class="font-bold">de.json <span class="text-on-surface-variant text-sm">(optional i18n)</span></p>
                <InputFile OnChange="OnDeI18nSelected" accept=".json" />
                @if (_deI18nLoaded)
                {
                    <span class="text-on-tertiary-container flex items-center justify-center gap-1 mt-2"><span class="material-symbols-outlined text-[18px]">check_circle</span> Loaded</span>
                }
            </div>

            <div class="border-2 border-dashed border-outline-variant/50 rounded-xl p-8 text-center hover:border-secondary hover:bg-surface-container-low transition-all cursor-pointer mb-6">
                <span class="material-symbols-outlined text-4xl text-on-surface-variant mb-2 block">translate</span>
                <p class="font-bold">fr.json <span class="text-on-surface-variant text-sm">(optional i18n)</span></p>
                <InputFile OnChange="OnFrI18nSelected" accept=".json" />
                @if (_frI18nLoaded)
                {
                    <span class="text-on-tertiary-container flex items-center justify-center gap-1 mt-2"><span class="material-symbols-outlined text-[18px]">check_circle</span> Loaded</span>
                }
            </div>

            <div class="border-2 border-dashed border-outline-variant/50 rounded-xl p-8 text-center hover:border-secondary hover:bg-surface-container-low transition-all cursor-pointer mb-6">
                <span class="material-symbols-outlined text-4xl text-on-surface-variant mb-2 block">menu_book</span>
                <p class="font-bold">README.md <span class="text-on-surface-variant text-sm">(optional)</span></p>
                <InputFile OnChange="OnReadmeSelected" accept=".md" />
                @if (_readmeLoaded)
                {
                    <span class="text-on-tertiary-container flex items-center justify-center gap-1 mt-2"><span class="material-symbols-outlined text-[18px]">check_circle</span> Loaded</span>
                }
            </div>

            <button type="submit" class="px-8 py-3 bg-secondary text-on-secondary rounded-lg font-bold hover:opacity-90 active:scale-[0.98] transition-all disabled:opacity-50 flex items-center gap-2" disabled="@(_isSubmitting || !_manifestLoaded || !_enI18nLoaded)">
                @if (_isSubmitting)
                {
                    <div class="animate-spin w-5 h-5 border-2 border-white border-t-transparent rounded-full"></div>
                }
                <span class="material-symbols-outlined text-[20px]">send</span> Submit for Review
            </button>
        </EditForm>
    }
</div>

@code {
    private PluginUploadModel _model = new();
    private string _manifestJson = string.Empty;
    private Dictionary<string, string> _i18nFiles = new();
    private string _readmeContent = string.Empty;
    private bool _manifestLoaded;
    private bool _enI18nLoaded;
    private bool _deI18nLoaded;
    private bool _frI18nLoaded;
    private bool _readmeLoaded;
    private bool _isSubmitting;
    private bool _isAuthenticated;
    private int _userId;
    private string _errorMessage = string.Empty;
    private string _successMessage = string.Empty;

    protected override void OnInitialized()
    {
        var user = HttpContextAccessor.HttpContext?.User;
        _isAuthenticated = user?.Identity?.IsAuthenticated ?? false;
        if (_isAuthenticated)
        {
            var idClaim = user?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (int.TryParse(idClaim, out var id))
            {
                _userId = id;
            }
        }
    }

    private async Task OnManifestSelected(InputFileChangeEventArgs e)
    {
        _errorMessage = string.Empty;
        try
        {
            using var reader = new StreamReader(e.File.OpenReadStream(AppConstants.PluginMaxUploadSizeBytes));
            _manifestJson = await reader.ReadToEndAsync();
            var (isValid, error) = PluginValidation.ValidatePluginManifest(_manifestJson);
            if (!isValid)
            {
                _errorMessage = $"Manifest: {error}";
                _manifestLoaded = false;
                return;
            }
            _manifestLoaded = true;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error reading manifest: {ex.Message}";
            _manifestLoaded = false;
        }
    }

    private async Task OnEnI18nSelected(InputFileChangeEventArgs e) => await LoadI18nFile(e, "en", v => _enI18nLoaded = v);
    private async Task OnDeI18nSelected(InputFileChangeEventArgs e) => await LoadI18nFile(e, "de", v => _deI18nLoaded = v);
    private async Task OnFrI18nSelected(InputFileChangeEventArgs e) => await LoadI18nFile(e, "fr", v => _frI18nLoaded = v);

    private async Task LoadI18nFile(InputFileChangeEventArgs e, string lang, Action<bool> setLoaded)
    {
        _errorMessage = string.Empty;
        try
        {
            using var reader = new StreamReader(e.File.OpenReadStream(AppConstants.PluginMaxUploadSizeBytes));
            var json = await reader.ReadToEndAsync();
            var (isValid, error) = PluginValidation.ValidateI18nFile(json);
            if (!isValid)
            {
                _errorMessage = $"i18n ({lang}): {error}";
                setLoaded(false);
                return;
            }
            _i18nFiles[lang] = json;
            setLoaded(true);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error reading i18n ({lang}): {ex.Message}";
            setLoaded(false);
        }
    }

    private async Task OnReadmeSelected(InputFileChangeEventArgs e)
    {
        _errorMessage = string.Empty;
        try
        {
            using var reader = new StreamReader(e.File.OpenReadStream(AppConstants.PluginMaxUploadSizeBytes));
            _readmeContent = await reader.ReadToEndAsync();
            _readmeLoaded = true;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error reading README: {ex.Message}";
            _readmeLoaded = false;
        }
    }

    private async Task HandleUpload()
    {
        _errorMessage = string.Empty;
        _successMessage = string.Empty;
        _isSubmitting = true;

        try
        {
            if (string.IsNullOrWhiteSpace(_model.Name) || string.IsNullOrWhiteSpace(_model.DisplayName))
            {
                _errorMessage = "Name and Display Name are required";
                return;
            }

            if (string.IsNullOrWhiteSpace(_model.Category))
            {
                _errorMessage = "Category is required";
                return;
            }

            var i18nCombined = System.Text.Json.JsonSerializer.Serialize(_i18nFiles);

            var bundleData = BuildZipBundle();

            var plugin = new FeaturePlugin
            {
                Name = _model.Name.Trim().ToLowerInvariant(),
                DisplayName = _model.DisplayName.Trim(),
                Category = _model.Category,
                Version = _model.Version.Trim(),
                Description = _model.Description?.Trim() ?? string.Empty,
                MinKlacksVersion = _model.MinKlacksVersion.Trim(),
                ReadmeMarkdown = _readmeContent,
                AuthorId = _userId
            };

            await PluginService.CreatePluginAsync(plugin, _manifestJson, i18nCombined, bundleData, _model.ChangeLog?.Trim());
            _successMessage = "Plugin submitted for review!";
            ResetForm();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private byte[] BuildZipBundle()
    {
        using var memoryStream = new MemoryStream();
        using (var archive = new System.IO.Compression.ZipArchive(memoryStream, System.IO.Compression.ZipArchiveMode.Create, true))
        {
            AddEntry(archive, "manifest.json", _manifestJson);

            foreach (var (lang, json) in _i18nFiles)
            {
                AddEntry(archive, $"i18n/{lang}.json", json);
            }

            if (_readmeLoaded && !string.IsNullOrWhiteSpace(_readmeContent))
            {
                AddEntry(archive, "README.md", _readmeContent);
            }
        }
        return memoryStream.ToArray();
    }

    private static void AddEntry(System.IO.Compression.ZipArchive archive, string path, string content)
    {
        var entry = archive.CreateEntry(path);
        using var writer = new StreamWriter(entry.Open());
        writer.Write(content);
    }

    private void ResetForm()
    {
        _model = new();
        _manifestJson = string.Empty;
        _i18nFiles.Clear();
        _readmeContent = string.Empty;
        _manifestLoaded = false;
        _enI18nLoaded = false;
        _deI18nLoaded = false;
        _frI18nLoaded = false;
        _readmeLoaded = false;
    }

    private class PluginUploadModel
    {
        public string Name { get; set; } = string.Empty;
        public string DisplayName { get; set; } = string.Empty;
        public string Category { get; set; } = string.Empty;
        public string Version { get; set; } = "1.0.0";
        public string Description { get; set; } = string.Empty;
        public string MinKlacksVersion { get; set; } = "1.0.0";
        public string? ChangeLog { get; set; }
    }
}
