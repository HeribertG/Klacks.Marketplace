@page "/upload"
@inject IPackageService PackageService
@inject IFileValidationService FileValidation
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation

<PageTitle>Upload Package - Klacks Store</PageTitle>

<div class="max-w-4xl mx-auto px-6 py-8">
    <h1 class="text-3xl font-black tracking-tight mb-2">
        <span class="material-symbols-outlined text-[32px] align-middle mr-1">upload</span> Upload Language Pack
    </h1>
    <p class="text-on-surface-variant mb-8">Share your language pack with the community</p>

    @if (!_isAuthenticated)
    {
        <div class="bg-secondary-fixed text-on-secondary-fixed-variant rounded-lg p-4 mb-6 text-sm">
            Please <a href="/login" class="underline font-semibold">login</a> to upload packages.
        </div>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <div class="bg-error-container text-on-error-container rounded-lg p-4 mb-6 text-sm">@_errorMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(_successMessage))
        {
            <div class="bg-tertiary-fixed text-on-tertiary-fixed-variant rounded-lg p-4 mb-6 text-sm">@_successMessage</div>
        }

        <EditForm Model="@_model" OnValidSubmit="HandleUpload">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div>
                    <label class="block text-sm font-semibold text-on-surface mb-2">Code (e.g. fr-FR)</label>
                    <InputText class="w-full px-4 py-3 bg-surface-container-low border border-outline-variant/30 rounded-lg text-on-surface focus:ring-2 focus:ring-secondary focus:bg-surface-container-lowest outline-none transition-all" @bind-Value="_model.Code" placeholder="xx-XX" />
                </div>
                <div>
                    <label class="block text-sm font-semibold text-on-surface mb-2">Display Name</label>
                    <InputText class="w-full px-4 py-3 bg-surface-container-low border border-outline-variant/30 rounded-lg text-on-surface focus:ring-2 focus:ring-secondary focus:bg-surface-container-lowest outline-none transition-all" @bind-Value="_model.DisplayName" placeholder="e.g. French (France)" />
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div>
                    <label class="block text-sm font-semibold text-on-surface mb-2">Speech Locale</label>
                    <InputText class="w-full px-4 py-3 bg-surface-container-low border border-outline-variant/30 rounded-lg text-on-surface focus:ring-2 focus:ring-secondary focus:bg-surface-container-lowest outline-none transition-all" @bind-Value="_model.SpeechLocale" placeholder="e.g. fr-FR" />
                </div>
                <div>
                    <label class="block text-sm font-semibold text-on-surface mb-2">Version</label>
                    <InputText class="w-full px-4 py-3 bg-surface-container-low border border-outline-variant/30 rounded-lg text-on-surface focus:ring-2 focus:ring-secondary focus:bg-surface-container-lowest outline-none transition-all" @bind-Value="_model.Version" placeholder="1.0.0" />
                </div>
            </div>

            <div class="mb-6">
                <label class="block text-sm font-semibold text-on-surface mb-2">Description</label>
                <InputTextArea class="w-full px-4 py-3 bg-surface-container-low border border-outline-variant/30 rounded-lg text-on-surface focus:ring-2 focus:ring-secondary focus:bg-surface-container-lowest outline-none transition-all" @bind-Value="_model.Description" rows="3"
                               placeholder="Describe your language pack..." />
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div>
                    <label class="block text-sm font-semibold text-on-surface mb-2">Coverage (%)</label>
                    <InputNumber class="w-full px-4 py-3 bg-surface-container-low border border-outline-variant/30 rounded-lg text-on-surface focus:ring-2 focus:ring-secondary focus:bg-surface-container-lowest outline-none transition-all" @bind-Value="_model.Coverage" min="0" max="100" />
                </div>
                <div>
                    <label class="block text-sm font-semibold text-on-surface mb-2">Min Klacks Version</label>
                    <InputText class="w-full px-4 py-3 bg-surface-container-low border border-outline-variant/30 rounded-lg text-on-surface focus:ring-2 focus:ring-secondary focus:bg-surface-container-lowest outline-none transition-all" @bind-Value="_model.MinKlacksVersion" placeholder="1.0.0" />
                </div>
            </div>

            <div class="border-2 border-dashed border-outline-variant/50 rounded-xl p-8 text-center hover:border-secondary hover:bg-surface-container-low transition-all cursor-pointer mb-6">
                <span class="material-symbols-outlined text-4xl text-on-surface-variant mb-2 block">description</span>
                <p class="font-bold">manifest.json</p>
                <InputFile OnChange="OnManifestSelected" accept=".json" />
                @if (_manifestLoaded)
                {
                    <span class="text-on-tertiary-container flex items-center justify-center gap-1 mt-2"><span class="material-symbols-outlined text-[18px]">check_circle</span> Loaded</span>
                }
            </div>

            <div class="border-2 border-dashed border-outline-variant/50 rounded-xl p-8 text-center hover:border-secondary hover:bg-surface-container-low transition-all cursor-pointer mb-6">
                <span class="material-symbols-outlined text-4xl text-on-surface-variant mb-2 block">translate</span>
                <p class="font-bold">translations.json</p>
                <InputFile OnChange="OnTranslationsSelected" accept=".json" />
                @if (_translationsLoaded)
                {
                    <span class="text-on-tertiary-container flex items-center justify-center gap-1 mt-2"><span class="material-symbols-outlined text-[18px]">check_circle</span> Loaded</span>
                }
            </div>

            <div class="border-2 border-dashed border-outline-variant/50 rounded-xl p-8 text-center hover:border-secondary hover:bg-surface-container-low transition-all cursor-pointer mb-6">
                <span class="material-symbols-outlined text-4xl text-on-surface-variant mb-2 block">menu_book</span>
                <p class="font-bold">docs.json <span class="text-on-surface-variant text-sm">(optional)</span></p>
                <InputFile OnChange="OnDocsSelected" accept=".json" />
                @if (_docsLoaded)
                {
                    <span class="text-on-tertiary-container flex items-center justify-center gap-1 mt-2"><span class="material-symbols-outlined text-[18px]">check_circle</span> Loaded</span>
                }
            </div>

            <div class="border-2 border-dashed border-outline-variant/50 rounded-xl p-8 text-center hover:border-secondary hover:bg-surface-container-low transition-all cursor-pointer mb-6">
                <span class="material-symbols-outlined text-4xl text-on-surface-variant mb-2 block">public</span>
                <p class="font-bold">countries.json <span class="text-on-surface-variant text-sm">(optional)</span></p>
                <InputFile OnChange="OnCountriesSelected" accept=".json" />
                @if (_countriesLoaded)
                {
                    <span class="text-on-tertiary-container flex items-center justify-center gap-1 mt-2"><span class="material-symbols-outlined text-[18px]">check_circle</span> Loaded</span>
                }
            </div>

            <div class="border-2 border-dashed border-outline-variant/50 rounded-xl p-8 text-center hover:border-secondary hover:bg-surface-container-low transition-all cursor-pointer mb-6">
                <span class="material-symbols-outlined text-4xl text-on-surface-variant mb-2 block">location_on</span>
                <p class="font-bold">states.json <span class="text-on-surface-variant text-sm">(optional)</span></p>
                <InputFile OnChange="OnStatesSelected" accept=".json" />
                @if (_statesLoaded)
                {
                    <span class="text-on-tertiary-container flex items-center justify-center gap-1 mt-2"><span class="material-symbols-outlined text-[18px]">check_circle</span> Loaded</span>
                }
            </div>

            <div class="border-2 border-dashed border-outline-variant/50 rounded-xl p-8 text-center hover:border-secondary hover:bg-surface-container-low transition-all cursor-pointer mb-6">
                <span class="material-symbols-outlined text-4xl text-on-surface-variant mb-2 block">calendar_month</span>
                <p class="font-bold">calendar-rules.json <span class="text-on-surface-variant text-sm">(optional)</span></p>
                <InputFile OnChange="OnCalendarRulesSelected" accept=".json" />
                @if (_calendarRulesLoaded)
                {
                    <span class="text-on-tertiary-container flex items-center justify-center gap-1 mt-2"><span class="material-symbols-outlined text-[18px]">check_circle</span> Loaded</span>
                }
            </div>

            <button type="submit" class="px-8 py-3 bg-secondary text-on-secondary rounded-lg font-bold hover:opacity-90 active:scale-[0.98] transition-all disabled:opacity-50 flex items-center gap-2" disabled="@(_isSubmitting || !_manifestLoaded || !_translationsLoaded)">
                @if (_isSubmitting)
                {
                    <div class="animate-spin w-5 h-5 border-2 border-white border-t-transparent rounded-full"></div>
                }
                <span class="material-symbols-outlined text-[20px]">send</span> Submit for Review
            </button>
        </EditForm>
    }
</div>

@code {
    private UploadModel _model = new();
    private string _manifestJson = string.Empty;
    private string _translationsJson = string.Empty;
    private string _docsJson = string.Empty;
    private string _countriesJson = string.Empty;
    private string _statesJson = string.Empty;
    private string _calendarRulesJson = string.Empty;
    private bool _manifestLoaded;
    private bool _translationsLoaded;
    private bool _docsLoaded;
    private bool _countriesLoaded;
    private bool _statesLoaded;
    private bool _calendarRulesLoaded;
    private bool _isSubmitting;
    private bool _isAuthenticated;
    private int _userId;
    private string _errorMessage = string.Empty;
    private string _successMessage = string.Empty;

    protected override void OnInitialized()
    {
        var user = HttpContextAccessor.HttpContext?.User;
        _isAuthenticated = user?.Identity?.IsAuthenticated ?? false;
        if (_isAuthenticated)
        {
            var idClaim = user?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (int.TryParse(idClaim, out var id))
            {
                _userId = id;
            }
        }
    }

    private async Task OnManifestSelected(InputFileChangeEventArgs e)
    {
        _errorMessage = string.Empty;
        try
        {
            using var reader = new StreamReader(e.File.OpenReadStream(AppConstants.MaxUploadSizeBytes));
            _manifestJson = await reader.ReadToEndAsync();
            var (isValid, error) = FileValidation.ValidateManifest(_manifestJson);
            if (!isValid)
            {
                _errorMessage = $"Manifest: {error}";
                _manifestLoaded = false;
                return;
            }
            _manifestLoaded = true;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error reading manifest: {ex.Message}";
            _manifestLoaded = false;
        }
    }

    private async Task OnTranslationsSelected(InputFileChangeEventArgs e)
    {
        _errorMessage = string.Empty;
        try
        {
            using var reader = new StreamReader(e.File.OpenReadStream(AppConstants.MaxUploadSizeBytes));
            _translationsJson = await reader.ReadToEndAsync();
            var (isValid, error) = FileValidation.ValidateTranslations(_translationsJson);
            if (!isValid)
            {
                _errorMessage = $"Translations: {error}";
                _translationsLoaded = false;
                return;
            }
            _translationsLoaded = true;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error reading translations: {ex.Message}";
            _translationsLoaded = false;
        }
    }

    private async Task OnDocsSelected(InputFileChangeEventArgs e)
    {
        _errorMessage = string.Empty;
        try
        {
            using var reader = new StreamReader(e.File.OpenReadStream(AppConstants.MaxUploadSizeBytes));
            _docsJson = await reader.ReadToEndAsync();
            var (isValid, error) = FileValidation.ValidateDocs(_docsJson);
            if (!isValid)
            {
                _errorMessage = $"Docs: {error}";
                _docsLoaded = false;
                return;
            }
            _docsLoaded = true;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error reading docs: {ex.Message}";
            _docsLoaded = false;
        }
    }

    private async Task OnCountriesSelected(InputFileChangeEventArgs e)
    {
        _errorMessage = string.Empty;
        try
        {
            using var reader = new StreamReader(e.File.OpenReadStream(AppConstants.MaxUploadSizeBytes));
            _countriesJson = await reader.ReadToEndAsync();
            var (isValid, error) = FileValidation.ValidateCountriesJson(_countriesJson);
            if (!isValid)
            {
                _errorMessage = $"Countries: {error}";
                _countriesLoaded = false;
                return;
            }
            _countriesLoaded = true;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error reading countries: {ex.Message}";
            _countriesLoaded = false;
        }
    }

    private async Task OnStatesSelected(InputFileChangeEventArgs e)
    {
        _errorMessage = string.Empty;
        try
        {
            using var reader = new StreamReader(e.File.OpenReadStream(AppConstants.MaxUploadSizeBytes));
            _statesJson = await reader.ReadToEndAsync();
            var (isValid, error) = FileValidation.ValidateStatesJson(_statesJson);
            if (!isValid)
            {
                _errorMessage = $"States: {error}";
                _statesLoaded = false;
                return;
            }
            _statesLoaded = true;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error reading states: {ex.Message}";
            _statesLoaded = false;
        }
    }

    private async Task OnCalendarRulesSelected(InputFileChangeEventArgs e)
    {
        _errorMessage = string.Empty;
        try
        {
            using var reader = new StreamReader(e.File.OpenReadStream(AppConstants.MaxUploadSizeBytes));
            _calendarRulesJson = await reader.ReadToEndAsync();
            var (isValid, error) = FileValidation.ValidateCalendarRulesJson(_calendarRulesJson);
            if (!isValid)
            {
                _errorMessage = $"Calendar rules: {error}";
                _calendarRulesLoaded = false;
                return;
            }
            _calendarRulesLoaded = true;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error reading calendar rules: {ex.Message}";
            _calendarRulesLoaded = false;
        }
    }

    private async Task HandleUpload()
    {
        _errorMessage = string.Empty;
        _successMessage = string.Empty;
        _isSubmitting = true;

        try
        {
            if (string.IsNullOrWhiteSpace(_model.Code) || string.IsNullOrWhiteSpace(_model.DisplayName))
            {
                _errorMessage = "Code and Display Name are required";
                return;
            }

            var package = new LanguagePackage
            {
                Code = _model.Code.Trim(),
                Name = _model.Code.Trim(),
                DisplayName = _model.DisplayName.Trim(),
                SpeechLocale = _model.SpeechLocale.Trim(),
                Version = _model.Version.Trim(),
                Description = _model.Description?.Trim() ?? string.Empty,
                Coverage = _model.Coverage,
                MinKlacksVersion = _model.MinKlacksVersion.Trim(),
                AuthorId = _userId
            };

            await PackageService.CreatePackageAsync(
                package,
                _manifestJson,
                _translationsJson,
                _docsLoaded ? _docsJson : null,
                _countriesLoaded ? _countriesJson : null,
                _statesLoaded ? _statesJson : null,
                _calendarRulesLoaded ? _calendarRulesJson : null);
            _successMessage = "Package submitted for review!";
            _model = new();
            _manifestLoaded = false;
            _translationsLoaded = false;
            _docsLoaded = false;
            _countriesLoaded = false;
            _statesLoaded = false;
            _calendarRulesLoaded = false;
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private class UploadModel
    {
        public string Code { get; set; } = string.Empty;
        public string DisplayName { get; set; } = string.Empty;
        public string SpeechLocale { get; set; } = string.Empty;
        public string Version { get; set; } = "1.0.0";
        public string Description { get; set; } = string.Empty;
        public double Coverage { get; set; }
        public string MinKlacksVersion { get; set; } = "1.0.0";
    }
}
