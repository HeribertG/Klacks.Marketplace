@page "/my-packages"
@inject IPackageService PackageService
@inject IFeaturePluginMarketplaceService PluginService
@inject IHttpContextAccessor HttpContextAccessor
@inject IStringLocalizer<SharedResource> L

<PageTitle>My Packages - Klacks Store</PageTitle>

<div class="max-w-5xl mx-auto px-6 py-8">
    <h1 class="text-3xl font-black tracking-tight mb-8">
        <span class="material-symbols-outlined text-3xl mr-2 align-middle">inventory_2</span> @L["MyPackages_Title"]
    </h1>

    @if (!_isAuthenticated)
    {
        <div class="bg-secondary-fixed text-on-secondary-fixed-variant rounded-xl px-6 py-4">
            @L["MyPackages_LoginRequired"] <a href="/login" class="text-secondary hover:underline no-underline font-medium">@L["Common_LoginLink"]</a>
        </div>
    }
    else if (_isLoading)
    {
        <div class="py-16 text-center">
            <div class="animate-spin inline-block w-8 h-8 border-4 border-secondary border-t-transparent rounded-full"></div>
        </div>
    }
    else
    {
        <div class="flex gap-3 mb-8">
            <button class="px-6 py-2.5 rounded-full font-bold transition-all @(_activeTab == "packages" ? "bg-secondary text-on-secondary" : "bg-surface-container text-on-surface-variant hover:bg-surface-container-high")"
                    @onclick='() => _activeTab = "packages"'>
                <span class="material-symbols-outlined text-[18px] mr-1">language</span> @L["Common_LanguagePacks"] (@_packages.Count)
            </button>
            <button class="px-6 py-2.5 rounded-full font-bold transition-all @(_activeTab == "plugins" ? "bg-secondary text-on-secondary" : "bg-surface-container text-on-surface-variant hover:bg-surface-container-high")"
                    @onclick='() => _activeTab = "plugins"'>
                <span class="material-symbols-outlined text-[18px] mr-1">extension</span> @L["Common_FeaturePlugins"] (@_plugins.Count)
            </button>
        </div>

        @if (_activeTab == "packages")
        {
            @if (_packages.Count == 0)
            {
                <div class="py-16 text-center">
                    <span class="material-symbols-outlined text-6xl text-on-surface-variant mb-4 block">package_2</span>
                    <h3 class="text-xl font-bold mb-2">@L["MyPackages_NoPacks"]</h3>
                    <p class="text-on-surface-variant mb-6">@L["MyPackages_NoPacksDesc"]</p>
                    <a href="/upload" class="px-6 py-3 bg-secondary text-on-secondary rounded-lg font-semibold no-underline hover:opacity-90 transition-all">
                        <span class="material-symbols-outlined text-[18px] mr-1 align-middle">upload</span> @L["MyPackages_UploadFirst"]
                    </a>
                </div>
            }
            else
            {
                <div class="bg-surface-container-lowest rounded-xl overflow-hidden shadow-[0_4px_12px_rgba(27,27,29,0.04)]">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="bg-surface-container-low text-on-surface-variant text-xs uppercase tracking-wider">
                                <th class="px-6 py-4 text-left font-bold">@L["Common_Package"]</th>
                                <th class="px-6 py-4 text-left font-bold">@L["Common_Code"]</th>
                                <th class="px-6 py-4 text-left font-bold">@L["Common_Version"]</th>
                                <th class="px-6 py-4 text-left font-bold">@L["Common_Coverage"]</th>
                                <th class="px-6 py-4 text-left font-bold">@L["Common_Downloads"]</th>
                                <th class="px-6 py-4 text-left font-bold">@L["Common_Status"]</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-outline-variant/20">
                            @foreach (var pkg in _packages)
                            {
                                <tr class="hover:bg-surface-container-low/50 transition-colors">
                                    <td class="px-6 py-4"><a href="/package/@pkg.Code" class="text-secondary hover:underline no-underline font-medium">@pkg.DisplayName</a></td>
                                    <td class="px-6 py-4"><code class="text-xs bg-surface-container-low px-2 py-1 rounded">@pkg.Code</code></td>
                                    <td class="px-6 py-4">@pkg.Version</td>
                                    <td class="px-6 py-4">@pkg.Coverage.ToString("F0")%</td>
                                    <td class="px-6 py-4">@pkg.Downloads</td>
                                    <td class="px-6 py-4"><StatusBadge Status="@pkg.Status" /></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
        else
        {
            @if (_plugins.Count == 0)
            {
                <div class="py-16 text-center">
                    <span class="material-symbols-outlined text-6xl text-on-surface-variant mb-4 block">extension</span>
                    <h3 class="text-xl font-bold mb-2">@L["MyPackages_NoPlugins"]</h3>
                    <p class="text-on-surface-variant mb-6">@L["MyPackages_NoPluginsDesc"]</p>
                    <a href="/upload-plugin" class="px-6 py-3 bg-secondary text-on-secondary rounded-lg font-semibold no-underline hover:opacity-90 transition-all">
                        <span class="material-symbols-outlined text-[18px] mr-1 align-middle">upload</span> @L["MyPackages_UploadFirstPlugin"]
                    </a>
                </div>
            }
            else
            {
                <div class="bg-surface-container-lowest rounded-xl overflow-hidden shadow-[0_4px_12px_rgba(27,27,29,0.04)]">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="bg-surface-container-low text-on-surface-variant text-xs uppercase tracking-wider">
                                <th class="px-6 py-4 text-left font-bold">@L["Common_Plugin"]</th>
                                <th class="px-6 py-4 text-left font-bold">@L["Common_Category"]</th>
                                <th class="px-6 py-4 text-left font-bold">@L["Common_Version"]</th>
                                <th class="px-6 py-4 text-left font-bold">@L["Common_Downloads"]</th>
                                <th class="px-6 py-4 text-left font-bold">@L["Common_Status"]</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-outline-variant/20">
                            @foreach (var plugin in _plugins)
                            {
                                <tr class="hover:bg-surface-container-low/50 transition-colors">
                                    <td class="px-6 py-4"><a href="/plugin/@plugin.Name" class="text-secondary hover:underline no-underline font-medium">@plugin.DisplayName</a></td>
                                    <td class="px-6 py-4"><CategoryBadge Category="@plugin.Category" /></td>
                                    <td class="px-6 py-4">@plugin.Version</td>
                                    <td class="px-6 py-4">@plugin.Downloads</td>
                                    <td class="px-6 py-4"><StatusBadge Status="@plugin.Status" /></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
    }
</div>

@code {
    private List<LanguagePackage> _packages = [];
    private List<FeaturePlugin> _plugins = [];
    private bool _isLoading = true;
    private bool _isAuthenticated;
    private int _userId;
    private string _activeTab = "packages";

    protected override async Task OnInitializedAsync()
    {
        var user = HttpContextAccessor.HttpContext?.User;
        _isAuthenticated = user?.Identity?.IsAuthenticated ?? false;

        if (_isAuthenticated)
        {
            var idClaim = user?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (int.TryParse(idClaim, out var id))
            {
                _userId = id;
                _packages = await PackageService.GetUserPackagesAsync(_userId);
                _plugins = await PluginService.GetUserPluginsAsync(_userId);
            }
        }

        _isLoading = false;
    }
}
