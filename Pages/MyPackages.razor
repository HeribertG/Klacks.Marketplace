@page "/my-packages"
@inject IPackageService PackageService
@inject IFeaturePluginMarketplaceService PluginService
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>My Packages - Klacks Marketplace</PageTitle>

<div class="detail-container">
    <h1><i class="fas fa-box"></i> My Packages</h1>

    @if (!_isAuthenticated)
    {
        <div class="alert alert-warning">
            Please <a href="/login">login</a> to view your packages.
        </div>
    }
    else if (_isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else
    {
        <div class="d-flex gap-2 mb-4">
            <button class="btn @(_activeTab == "packages" ? "btn-primary" : "btn-outline-primary")"
                    @onclick='() => _activeTab = "packages"'>
                <i class="fas fa-globe"></i> Language Packs (@_packages.Count)
            </button>
            <button class="btn @(_activeTab == "plugins" ? "btn-primary" : "btn-outline-primary")"
                    @onclick='() => _activeTab = "plugins"'>
                <i class="fas fa-puzzle-piece"></i> Feature Plugins (@_plugins.Count)
            </button>
        </div>

        @if (_activeTab == "packages")
        {
            @if (_packages.Count == 0)
            {
                <div class="empty-state">
                    <i class="fas fa-box-open d-block"></i>
                    <h3>No language packs yet</h3>
                    <p>You haven't uploaded any language packs yet.</p>
                    <a href="/upload" class="btn btn-primary mt-3">
                        <i class="fas fa-upload"></i> Upload your first package
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-dark-custom">
                        <thead>
                            <tr>
                                <th>Package</th>
                                <th>Code</th>
                                <th>Version</th>
                                <th>Coverage</th>
                                <th>Downloads</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var pkg in _packages)
                            {
                                <tr>
                                    <td><a href="/package/@pkg.Code">@pkg.DisplayName</a></td>
                                    <td><code>@pkg.Code</code></td>
                                    <td>@pkg.Version</td>
                                    <td>@pkg.Coverage.ToString("F0")%</td>
                                    <td>@pkg.Downloads</td>
                                    <td><StatusBadge Status="@pkg.Status" /></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
        else
        {
            @if (_plugins.Count == 0)
            {
                <div class="empty-state">
                    <i class="fas fa-puzzle-piece d-block"></i>
                    <h3>No feature plugins yet</h3>
                    <p>You haven't uploaded any feature plugins yet.</p>
                    <a href="/upload-plugin" class="btn btn-primary mt-3">
                        <i class="fas fa-upload"></i> Upload your first plugin
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-dark-custom">
                        <thead>
                            <tr>
                                <th>Plugin</th>
                                <th>Category</th>
                                <th>Version</th>
                                <th>Downloads</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var plugin in _plugins)
                            {
                                <tr>
                                    <td><a href="/plugin/@plugin.Name">@plugin.DisplayName</a></td>
                                    <td><CategoryBadge Category="@plugin.Category" /></td>
                                    <td>@plugin.Version</td>
                                    <td>@plugin.Downloads</td>
                                    <td><StatusBadge Status="@plugin.Status" /></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
    }
</div>

@code {
    private List<LanguagePackage> _packages = [];
    private List<FeaturePlugin> _plugins = [];
    private bool _isLoading = true;
    private bool _isAuthenticated;
    private int _userId;
    private string _activeTab = "packages";

    protected override async Task OnInitializedAsync()
    {
        var user = HttpContextAccessor.HttpContext?.User;
        _isAuthenticated = user?.Identity?.IsAuthenticated ?? false;

        if (_isAuthenticated)
        {
            var idClaim = user?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (int.TryParse(idClaim, out var id))
            {
                _userId = id;
                _packages = await PackageService.GetUserPackagesAsync(_userId);
                _plugins = await PluginService.GetUserPluginsAsync(_userId);
            }
        }

        _isLoading = false;
    }
}
