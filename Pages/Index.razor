@page "/"
@inject IPackageService PackageService

<PageTitle>Klacks Language Marketplace</PageTitle>

<div class="hero-section">
    <h1><i class="fas fa-globe"></i> Klacks Language Marketplace</h1>
    <p>Discover and share language packs for your Klacks application</p>
</div>

<div class="search-container position-relative">
    <i class="fas fa-search search-icon"></i>
    <input type="text" class="form-control" placeholder="Search language packs..."
           @bind="_searchText" @bind:event="oninput" @onkeyup="OnSearchKeyUp" />
</div>

@if (_isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else if (_packages.Count == 0)
{
    <div class="empty-state">
        <i class="fas fa-box-open d-block"></i>
        <h3>No packages found</h3>
        <p>Be the first to upload a language pack!</p>
    </div>
}
else
{
    <div class="package-grid">
        @foreach (var package in _packages)
        {
            <PackageCard Package="@package" />
        }
    </div>

    @if (_totalPages > 1)
    {
        <div class="pagination-container">
            <button class="page-btn" disabled="@(_currentPage <= 1)" @onclick="PreviousPage">
                <i class="fas fa-chevron-left"></i>
            </button>
            @for (var i = 1; i <= _totalPages; i++)
            {
                var pageNum = i;
                <button class="page-btn @(pageNum == _currentPage ? "active" : "")" @onclick="() => GoToPage(pageNum)">
                    @pageNum
                </button>
            }
            <button class="page-btn" disabled="@(_currentPage >= _totalPages)" @onclick="NextPage">
                <i class="fas fa-chevron-right"></i>
            </button>
        </div>
    }
}

@code {
    private List<LanguagePackage> _packages = [];
    private string _searchText = string.Empty;
    private int _currentPage = 1;
    private int _totalPages;
    private int _totalCount;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadPackages();
    }

    private async Task LoadPackages()
    {
        _isLoading = true;
        var (items, totalCount) = await PackageService.SearchPackagesAsync(_searchText, null, _currentPage, AppConstants.PageSize);
        _packages = items;
        _totalCount = totalCount;
        _totalPages = (int)Math.Ceiling((double)totalCount / AppConstants.PageSize);
        _isLoading = false;
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        _currentPage = 1;
        await LoadPackages();
    }

    private async Task GoToPage(int page)
    {
        _currentPage = page;
        await LoadPackages();
    }

    private async Task PreviousPage()
    {
        if (_currentPage > 1)
        {
            _currentPage--;
            await LoadPackages();
        }
    }

    private async Task NextPage()
    {
        if (_currentPage < _totalPages)
        {
            _currentPage++;
            await LoadPackages();
        }
    }
}
