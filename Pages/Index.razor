@page "/"
@inject IPackageService PackageService
@inject IFeaturePluginMarketplaceService PluginService

<PageTitle>Klacks Marketplace</PageTitle>

<div class="hero-section">
    <h1><i class="fas fa-store"></i> Klacks Marketplace</h1>
    <p>Discover and share language packs and feature plugins for your Klacks application</p>
</div>

<div class="d-flex justify-content-center mb-4">
    <div class="btn-group" role="group">
        <button class="btn @(_activeTab == Tab.LanguagePacks ? "btn-primary" : "btn-outline-primary")"
                @onclick="() => SwitchTab(Tab.LanguagePacks)">
            <i class="fas fa-globe"></i> Language Packs
        </button>
        <button class="btn @(_activeTab == Tab.FeaturePlugins ? "btn-primary" : "btn-outline-primary")"
                @onclick="() => SwitchTab(Tab.FeaturePlugins)">
            <i class="fas fa-puzzle-piece"></i> Feature Plugins
        </button>
    </div>
</div>

<div class="search-container position-relative">
    <i class="fas fa-search search-icon"></i>
    <input type="text" class="form-control"
           placeholder="@(_activeTab == Tab.LanguagePacks ? "Search language packs..." : "Search feature plugins...")"
           @bind="_searchText" @bind:event="oninput" @onkeyup="OnSearchKeyUp" />
</div>

@if (_activeTab == Tab.FeaturePlugins)
{
    <div class="d-flex justify-content-center mb-3">
        <select class="form-control" style="max-width: 250px;" @onchange="OnCategoryChanged">
            <option value="">All categories</option>
            @foreach (var cat in PluginCategory.AllCategories)
            {
                <option value="@cat">@cat</option>
            }
        </select>
    </div>
}

@if (_isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else if (_activeTab == Tab.LanguagePacks && _packages.Count == 0)
{
    <div class="empty-state">
        <i class="fas fa-box-open d-block"></i>
        <h3>No packages found</h3>
        <p>Be the first to upload a language pack!</p>
    </div>
}
else if (_activeTab == Tab.FeaturePlugins && _plugins.Count == 0)
{
    <div class="empty-state">
        <i class="fas fa-puzzle-piece d-block"></i>
        <h3>No plugins found</h3>
        <p>Be the first to upload a feature plugin!</p>
    </div>
}
else
{
    <div class="package-grid">
        @if (_activeTab == Tab.LanguagePacks)
        {
            @foreach (var package in _packages)
            {
                <PackageCard Package="@package" />
            }
        }
        else
        {
            @foreach (var plugin in _plugins)
            {
                <PluginCard Plugin="@plugin" />
            }
        }
    </div>

    @if (_totalPages > 1)
    {
        <div class="pagination-container">
            <button class="page-btn" disabled="@(_currentPage <= 1)" @onclick="PreviousPage">
                <i class="fas fa-chevron-left"></i>
            </button>
            @for (var i = 1; i <= _totalPages; i++)
            {
                var pageNum = i;
                <button class="page-btn @(pageNum == _currentPage ? "active" : "")" @onclick="() => GoToPage(pageNum)">
                    @pageNum
                </button>
            }
            <button class="page-btn" disabled="@(_currentPage >= _totalPages)" @onclick="NextPage">
                <i class="fas fa-chevron-right"></i>
            </button>
        </div>
    }
}

@code {
    private enum Tab { LanguagePacks, FeaturePlugins }

    private Tab _activeTab = Tab.LanguagePacks;
    private List<LanguagePackage> _packages = [];
    private List<FeaturePlugin> _plugins = [];
    private string _searchText = string.Empty;
    private string _selectedCategory = string.Empty;
    private int _currentPage = 1;
    private int _totalPages;
    private int _totalCount;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;

        if (_activeTab == Tab.LanguagePacks)
        {
            var (items, totalCount) = await PackageService.SearchPackagesAsync(_searchText, null, _currentPage, AppConstants.PageSize);
            _packages = items;
            _totalCount = totalCount;
        }
        else
        {
            var category = string.IsNullOrWhiteSpace(_selectedCategory) ? null : _selectedCategory;
            var (items, totalCount) = await PluginService.SearchPluginsAsync(_searchText, category, null, _currentPage, AppConstants.PageSize);
            _plugins = items;
            _totalCount = totalCount;
        }

        _totalPages = (int)Math.Ceiling((double)_totalCount / AppConstants.PageSize);
        _isLoading = false;
    }

    private async Task SwitchTab(Tab tab)
    {
        _activeTab = tab;
        _currentPage = 1;
        _searchText = string.Empty;
        _selectedCategory = string.Empty;
        await LoadData();
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        _currentPage = 1;
        await LoadData();
    }

    private async Task OnCategoryChanged(ChangeEventArgs e)
    {
        _selectedCategory = e.Value?.ToString() ?? string.Empty;
        _currentPage = 1;
        await LoadData();
    }

    private async Task GoToPage(int page)
    {
        _currentPage = page;
        await LoadData();
    }

    private async Task PreviousPage()
    {
        if (_currentPage > 1)
        {
            _currentPage--;
            await LoadData();
        }
    }

    private async Task NextPage()
    {
        if (_currentPage < _totalPages)
        {
            _currentPage++;
            await LoadData();
        }
    }
}
