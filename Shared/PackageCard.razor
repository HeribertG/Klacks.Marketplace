@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L

<div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant/30 transition-all cursor-pointer hover:shadow-[0_20px_50px_rgba(27,27,29,0.06)] hover:-translate-y-0.5"
     @onclick="NavigateToPackage">
    <div class="flex justify-between items-start mb-6">
        <span class="text-4xl">@GetFlagEmoji(Package.Code)</span>
        <span class="px-2 py-1 bg-surface-container text-xs font-bold rounded uppercase tracking-wider text-on-surface-variant">v@(Package.Version)</span>
    </div>
    <h3 class="text-xl font-bold mb-1">@Package.DisplayName</h3>
    <p class="text-sm text-on-surface-variant mb-6">@L["Common_ByAuthor", Package.Author.DisplayName]</p>
    <div class="space-y-2 mb-6">
        <div class="flex justify-between text-xs font-bold">
            <span>@L["Common_Coverage"]</span>
            <span class="text-on-tertiary-container">@(Package.Coverage)%</span>
        </div>
        <div class="w-full bg-surface-container h-1.5 rounded-full overflow-hidden">
            <div class="bg-gradient-to-r from-tertiary-fixed-dim to-on-tertiary-container h-full" style="width: @(Package.Coverage)%"></div>
        </div>
    </div>
    <div class="flex items-center gap-4 text-sm text-on-surface-variant">
        <span class="flex items-center gap-1">
            <span class="material-symbols-outlined text-[18px]">download</span> @FormatNumber(Package.Downloads)
        </span>
        <span class="flex items-center gap-1">
            <span class="material-symbols-outlined text-[18px]">translate</span> @FormatNumber(Package.TranslationCount)
        </span>
    </div>
</div>

@code {
    [Parameter]
    public LanguagePackage Package { get; set; } = null!;

    private void NavigateToPackage()
    {
        Navigation.NavigateTo($"/package/{Package.Code}");
    }

    private static string FormatNumber(int number) =>
        number >= 1000 ? $"{number / 1000.0:F1}k" : number.ToString();

    private static string GetFlagEmoji(string code)
    {
        var key = code.Length >= 5 ? code[3..5].ToUpperInvariant() : code[..2].ToUpperInvariant();
        var langToCountry = new Dictionary<string, string>
        {
            ["SV"] = "SE", ["JA"] = "JP", ["KO"] = "KR", ["EN"] = "GB",
            ["DA"] = "DK", ["ZH"] = "CN", ["HI"] = "IN", ["UK"] = "UA",
            ["VI"] = "VN", ["EL"] = "GR", ["CS"] = "CZ", ["HE"] = "IL",
            ["CA"] = "ES", ["EU"] = "ES", ["GL"] = "ES", ["NB"] = "NO",
            ["NN"] = "NO", ["SR"] = "RS", ["HR"] = "HR", ["BS"] = "BA",
            ["SL"] = "SI", ["SK"] = "SK", ["ET"] = "EE", ["LV"] = "LV",
            ["LT"] = "LT", ["MS"] = "MY", ["TH"] = "TH", ["ID"] = "ID",
            ["FA"] = "IR", ["BG"] = "BG", ["RO"] = "RO", ["HU"] = "HU",
            ["FI"] = "FI", ["AR"] = "SA"
        };
        var country = langToCountry.GetValueOrDefault(key, key);
        return CountryToFlag(country);
    }

    private static string CountryToFlag(string countryCode)
    {
        if (countryCode.Length != 2) return "\U0001F310";
        var first = char.ConvertFromUtf32(0x1F1E6 + (countryCode[0] - 'A'));
        var second = char.ConvertFromUtf32(0x1F1E6 + (countryCode[1] - 'A'));
        return first + second;
    }
}
