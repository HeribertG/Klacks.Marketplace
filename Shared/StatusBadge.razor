<span class="px-3 py-1 text-xs font-bold rounded-full @GetStatusClasses()">@GetStatusText()</span>

@code {
    [Parameter]
    public PackageStatus Status { get; set; }

    private string GetStatusClasses() => Status switch
    {
        PackageStatus.Published => "bg-tertiary-fixed text-on-tertiary-fixed-variant",
        PackageStatus.PendingReview => "bg-secondary-fixed text-on-secondary-fixed-variant",
        PackageStatus.Rejected => "bg-error-container text-on-error-container",
        PackageStatus.Draft => "bg-surface-container-highest text-on-surface-variant",
        _ => "bg-surface-container-highest text-on-surface-variant"
    };

    private string GetStatusText() => Status switch
    {
        PackageStatus.Published => "Published",
        PackageStatus.PendingReview => "Pending",
        PackageStatus.Rejected => "Rejected",
        PackageStatus.Draft => "Draft",
        _ => "Unknown"
    };
}
