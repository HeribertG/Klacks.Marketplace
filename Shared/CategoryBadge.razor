<span class="px-3 py-1 text-xs font-bold rounded-full @GetCategoryClasses()">@Category</span>

@code {
    [Parameter]
    public string Category { get; set; } = string.Empty;

    private string GetCategoryClasses() => Category?.ToLowerInvariant() switch
    {
        "communication" => "bg-blue-100 text-blue-700",
        "erp" => "bg-emerald-100 text-emerald-700",
        "accounting" => "bg-amber-100 text-amber-700",
        "reporting" => "bg-purple-100 text-purple-700",
        "integration" => "bg-cyan-100 text-cyan-700",
        _ => "bg-surface-container-highest text-on-surface-variant"
    };
}
