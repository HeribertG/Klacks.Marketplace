@inject IStringLocalizer<SharedResource> L

<div>
    <div class="w-full bg-surface-container h-2 rounded-full overflow-hidden">
        <div class="h-full transition-all rounded-full @GetCoverageClasses()" style="width: @Coverage%"></div>
    </div>
    <span class="text-xs font-bold text-on-surface-variant mt-1 block">@L["Common_CoveragePercent", Coverage.ToString("F0")]</span>
</div>

@code {
    [Parameter]
    public double Coverage { get; set; }

    private string GetCoverageClasses()
    {
        if (Coverage >= 80) return "bg-gradient-to-r from-tertiary-fixed-dim to-on-tertiary-container";
        if (Coverage >= 50) return "bg-gradient-to-r from-amber-400 to-amber-500";
        return "bg-gradient-to-r from-red-400 to-red-500";
    }
}
