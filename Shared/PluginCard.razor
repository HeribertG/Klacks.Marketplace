@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L

<div class="bg-surface-container-lowest p-8 rounded-xl transition-all cursor-pointer flex flex-col h-full hover:shadow-[0_20px_50px_rgba(27,27,29,0.06)] hover:-translate-y-0.5"
     @onclick="NavigateToPlugin">
    <div class="w-16 h-16 rounded-full flex items-center justify-center mb-8 @GetIconBgClass()">
        <span class="material-symbols-outlined text-3xl @GetIconTextClass()">@GetCategoryIcon()</span>
    </div>
    <div class="flex items-center gap-3 mb-4 flex-wrap">
        <h3 class="text-2xl font-bold">@Plugin.DisplayName</h3>
        <span class="px-3 py-1 bg-tertiary-fixed text-on-tertiary-fixed-variant text-xs font-bold rounded-full uppercase">@Plugin.Category</span>
    </div>
    <p class="text-on-surface-variant mb-8 flex-grow line-clamp-2">@Plugin.Description</p>
    <div class="flex items-center justify-between mt-auto pt-6 border-t border-outline-variant/20">
        <div class="flex items-center gap-2 text-sm font-semibold">
            <span class="material-symbols-outlined text-secondary">terminal</span>
            @L["Common_SkillsCount", _skills.Length]
        </div>
        <div class="text-sm text-on-surface-variant font-medium">
            @L["Common_InstallsCount", FormatNumber(Plugin.Downloads)]
        </div>
    </div>
</div>

@code {
    [Parameter]
    public FeaturePlugin Plugin { get; set; } = null!;

    private string[] _skills = [];

    protected override void OnParametersSet()
    {
        _skills = GetSkills();
    }

    private string[] GetSkills()
    {
        if (_skills.Length > 0) return _skills;
        try
        {
            if (!string.IsNullOrWhiteSpace(Plugin.ProvidedSkillsJson))
            {
                return System.Text.Json.JsonSerializer.Deserialize<string[]>(Plugin.ProvidedSkillsJson) ?? [];
            }
        }
        catch { }
        return [];
    }

    private void NavigateToPlugin()
    {
        Navigation.NavigateTo($"/plugin/{Plugin.Name}");
    }

    private static string FormatNumber(int number) =>
        number >= 1000 ? $"{number / 1000.0:F1}k" : number.ToString();

    private string GetCategoryIcon() => Plugin.Category?.ToLowerInvariant() switch
    {
        "communication" => "chat",
        "erp" => "hub",
        "accounting" => "account_balance",
        "reporting" => "query_stats",
        "integration" => "sync_alt",
        _ => "extension"
    };

    private string GetIconBgClass() => Plugin.Category?.ToLowerInvariant() switch
    {
        "communication" => "bg-blue-100",
        "erp" => "bg-emerald-100",
        "accounting" => "bg-amber-100",
        "reporting" => "bg-purple-100",
        "integration" => "bg-cyan-100",
        _ => "bg-slate-100"
    };

    private string GetIconTextClass() => Plugin.Category?.ToLowerInvariant() switch
    {
        "communication" => "text-secondary",
        "erp" => "text-on-tertiary-container",
        "accounting" => "text-amber-600",
        "reporting" => "text-purple-600",
        "integration" => "text-cyan-600",
        _ => "text-slate-600"
    };
}
