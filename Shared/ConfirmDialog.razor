@inject IStringLocalizer<SharedResource> L

@if (IsVisible)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm" @onclick="OnCancel">
        <div class="bg-surface-container-lowest rounded-2xl p-8 max-w-md w-full mx-4 shadow-[0_20px_50px_rgba(27,27,29,0.15)]" @onclick:stopPropagation="true">
            <h4 class="text-xl font-bold mb-2">@Title</h4>
            <p class="text-on-surface-variant mb-6">@Message</p>
            <div class="flex justify-end gap-3">
                <button class="px-5 py-2 text-on-surface-variant hover:bg-surface-container rounded-lg font-medium transition-all" @onclick="OnCancel">@L["Common_Cancel"]</button>
                <button class="px-5 py-2 bg-secondary text-on-secondary rounded-lg font-bold hover:opacity-90 active:scale-[0.98] transition-all" @onclick="OnConfirm">@L["Common_Confirm"]</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsVisible { get; set; }

    [Parameter]
    public string Title { get; set; } = "Confirm";

    [Parameter]
    public string Message { get; set; } = "Are you sure?";

    [Parameter]
    public EventCallback OnConfirm { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }
}
