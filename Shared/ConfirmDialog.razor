@if (IsVisible)
{
    <div class="confirm-overlay" @onclick="OnCancel">
        <div class="confirm-dialog" @onclick:stopPropagation="true">
            <h4>@Title</h4>
            <p class="text-muted">@Message</p>
            <div class="d-flex justify-content-end gap-2 mt-3">
                <button class="btn btn-secondary btn-sm" @onclick="OnCancel">Cancel</button>
                <button class="btn btn-primary btn-sm" @onclick="OnConfirm">Confirm</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsVisible { get; set; }

    [Parameter]
    public string Title { get; set; } = "Confirm";

    [Parameter]
    public string Message { get; set; } = "Are you sure?";

    [Parameter]
    public EventCallback OnConfirm { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }
}
