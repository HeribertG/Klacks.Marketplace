@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L

<div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant/30 transition-all cursor-pointer hover:shadow-[0_20px_50px_rgba(27,27,29,0.06)] hover:-translate-y-0.5"
     @onclick="NavigateToRegion">
    <div class="flex justify-between items-start mb-6">
        <span class="text-4xl">@GetFlagEmoji(RegionPackage.CountryCode)</span>
        <span class="px-2 py-1 bg-surface-container text-xs font-bold rounded uppercase tracking-wider text-on-surface-variant">v@(RegionPackage.Version)</span>
    </div>
    <h3 class="text-xl font-bold mb-1">@RegionPackage.CountryName</h3>
    <p class="text-sm text-on-surface-variant mb-6"><code class="text-xs bg-surface-container-low px-2 py-1 rounded uppercase">@RegionPackage.CountryCode</code></p>
    <div class="flex items-center justify-between mt-auto pt-4 border-t border-outline-variant/20">
        <span class="flex items-center gap-1 text-sm text-on-surface-variant">
            <span class="material-symbols-outlined text-[18px]">download</span> @FormatNumber(RegionPackage.Downloads)
        </span>
        <StatusBadge Status="@RegionPackage.Status" />
    </div>
</div>

@code {
    [Parameter]
    public RegionPackage RegionPackage { get; set; } = null!;

    private void NavigateToRegion()
    {
        Navigation.NavigateTo($"/region/{RegionPackage.CountryCode}");
    }

    private static string FormatNumber(int number) =>
        number >= 1000 ? $"{number / 1000.0:F1}k" : number.ToString();

    private static string GetFlagEmoji(string countryCode)
    {
        if (countryCode.Length < 2) return "\U0001F310";
        var code = countryCode[..2].ToUpperInvariant();
        var first = char.ConvertFromUtf32(0x1F1E6 + (code[0] - 'A'));
        var second = char.ConvertFromUtf32(0x1F1E6 + (code[1] - 'A'));
        return first + second;
    }
}
