# Klacks On-Prem (Docker) configuration.
# install.ps1 / install.sh generates a real .env from this template. Do not commit a filled .env.

# --- Compose project ---------------------------------------------------------
# Pinned so the host and the in-container updater operate on the SAME compose
# project regardless of the install directory name. Do not change after install.
COMPOSE_PROJECT_NAME=klacks

# --- Host / TLS --------------------------------------------------------------
# Hostname or IP clients use to reach Klacks. Used for the nginx server_name,
# the TLS certificate CN, JWT audience/issuer and CORS.
SERVER_NAME=localhost
HTTP_PORT=80
HTTPS_PORT=443

# --- Region setup (optional, one-time on first boot) --------------------------
# Set by install.ps1 -Region / REGION=<code> ./install.sh. Path inside the
# klacks-api container to a regions/<code>.json profile (locale, holidays,
# worktime limits, surcharges, industry presets — see regions/README.md).
# Leave empty to skip region setup.
REGION_SETUP_FILE=

# --- Secrets (generated by the installer — keep stable across re-runs) --------
# POSTGRES_PASSWORD is baked into the postgres data volume on first init; changing
# it later orphans the database. JWT_SECRET signs sessions; changing it logs everyone out.
POSTGRES_PASSWORD=
JWT_SECRET=

# --- Image versions ----------------------------------------------------------
# api/ui are pinned to an exact released version (set by the installer from the
# signed manifest) so both move together. The updater rides :latest (it is never
# part of the signed manifest and only swaps api/ui).
KLACKS_API_TAG=latest
KLACKS_UI_TAG=latest
KLACKS_UPDATER_TAG=latest

# --- Auto-update trust root (FIXED vendor values — do NOT randomize) ----------
# The manifest URL and the RSA public key are vendor constants. The public key
# must match the private key the vendor CI signs releases with.
UPDATE_MANIFEST_BASE_URL=https://github.com/HeribertG/Klacks.Api/releases/latest/download
UPDATE_SIGNATURE_PUBLIC_KEY=

# --- Auto-update behavior (DB settings override these; set via the admin UI) --
# Defaults applied on first boot. Leave AUTO_ENABLED=true for hands-off updates,
# or set NOTIFY_ONLY=true to detect-but-not-apply.
# UPDATE_AUTO_ENABLED=true
# UPDATE_NOTIFY_ONLY=false
